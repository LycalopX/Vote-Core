# ============================================
# Urna Eletrônica EESC — Variáveis de Ambiente
# ============================================

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Segurança
SECRET_KEY=troque-por-um-token-aleatório-de-32-chars
SALT_KEY=chave-secreta-hmac-para-hash-do-nusp
SALT_2=chave-secreta-hmac-para-audit-id-diferente-da-salt-key

# Aplicação
BASE_URL=http://localhost:8000
DATABASE_URL=sqlite+aiosqlite:///./votes.db
DEBUG=true

# ============================================
# Variáveis de Controle da Votação
# Modifique estas para configurar a urna
# ============================================

# Título da votação exibido na interface
VOTE_TITLE=Assembleia EESC-USP — Greve 2026

# Pergunta exibida ao eleitor
VOTE_QUESTION=Você é a favor da greve?

# Códigos de unidade USP elegíveis (separados por vírgula)
# 97 = Escola de Engenharia de São Carlos + ICMC (compartilham unidade)
# Deixe vazio para aceitar qualquer unidade
ELIGIBLE_UNIT_CODES=97

# Códigos de curso USP elegíveis (separados por vírgula)
# Filtro MAIS FINO que unidade — EESC e ICMC compartilham unidade 97!
# Se definido, TEM PRIORIDADE sobre ELIGIBLE_UNIT_CODES e keywords.
# Deixe vazio para usar apenas filtro por unidade/keywords.
# Exemplos de cursos EESC:
#   97001 = Engenharia de Computação
#   97002 = Engenharia Elétrica/Eletrônica
#   97003 = Engenharia Mecânica
#   97004 = Engenharia de Produção
#   97005 = Engenharia Civil
#   97006 = Engenharia Aeronáutica
#   97007 = Engenharia Mecatrônica
#   97008 = Engenharia Ambiental
# Para aceitar TODOS os cursos EESC:
# ELIGIBLE_COURSE_CODES=97001,97002,97003,97004,97005,97006,97007,97008
ELIGIBLE_COURSE_CODES=

# Palavras-chave para validar elegibilidade (separadas por |)
# Busca no texto do atestado, case-insensitive
# Só usado se ELIGIBLE_COURSE_CODES estiver vazio
ELIGIBLE_KEYWORDS=Escola de Engenharia de São Carlos|EESC

# Opções de voto (separadas por vírgula)
VOTE_OPTIONS=Sim,Não,Nulo
